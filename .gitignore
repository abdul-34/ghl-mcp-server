# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# Secrets & environment — NEVER commit these
# ---------------------------------------------------------------------------
# Ignore every .env variant (root + dashboard), but keep the example templates.
.env
.env.*
!.env.example
dashboard/.env
dashboard/.env.*
!dashboard/.env.example

# MCP / client configs that may embed tokens
cursor-mcp-config.json
*mcp-config*.json

# Keys & certificates
*.pem
*.key
*.p12
*.pfx
secrets.json
credentials.json

# ---------------------------------------------------------------------------
# Build output
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Generated / vendored: HighLevel OpenAPI specs cloned for tool generation.
# (We ship the generated tools in src/tools/generated/, not the source specs.)
# ---------------------------------------------------------------------------
.ghl-api-docs/

# ---------------------------------------------------------------------------
# IDE / editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Logs / runtime
# ---------------------------------------------------------------------------
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# Caches
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
.npm
.eslintcache
.turbo/

# ---------------------------------------------------------------------------
# Temp / misc
# ---------------------------------------------------------------------------
tmp/
temp/
.vercel
