# ============================================================================
# CRM MCP — environment
# Copy this file to `.env` and fill in the values, then `docker compose up`.
# ============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# From your Supabase project → Project Settings → API.

# Same URL, used by both services. (NEXT_PUBLIC_* is what the dashboard inlines.)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Anon (public) key — safe in the browser; RLS protects the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — MCP server ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Encryption ───────────────────────────────────────────────────────────────
# 32-byte key used to encrypt Private Integration Tokens at rest.
# The dashboard encrypts with it; the MCP server decrypts with it — they MUST match.
# Generate with:  openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-chars

# ── URLs ─────────────────────────────────────────────────────────────────────
# Public base URL of the MCP server. The dashboard uses it to build the
# /mcp/<token> links it shows to clients. In production set this to your
# externally reachable URL (e.g. https://mcp.youragency.com).
NEXT_PUBLIC_MCP_BASE_URL=http://localhost:8000

# ── MCP server ────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production
