# ── Dashboard environment ───────────────────────────────────────────────────

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public base URL of the MCP server (used to build the /mcp/<token> links shown
# to clients). In docker-compose this is the externally reachable URL.
NEXT_PUBLIC_MCP_BASE_URL=http://localhost:8000

# 32-byte key used to encrypt Private Integration Tokens before storing them.
# MUST be identical to the MCP server's ENCRYPTION_KEY.
# Generate with:  openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-chars
